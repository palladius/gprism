#!/usr/bin/env ruby
require 'yaml'
require 'openssl'
require 'digest'
require 'fileutils'
require 'shellwords'
require 'io/console'

require 'base64'

# Terminal colors
CYAN  = "\e[36m"
GREEN = "\e[32m"
RED   = "\e[31m"
BLUE  = "\e[34m"
RESET = "\e[0m"

def info(msg) puts "#{CYAN}INFO:#{RESET} #{msg}" end
def success(msg) puts "#{GREEN}SUCCESS:#{RESET} #{msg}" end
def error(msg) puts "#{RED}ERROR:#{RESET} #{msg}"; exit 1 end
def warn(msg) puts "#{RED}WARN:#{RESET} #{msg}" end

# Config loading
def load_config
  config = {}
  yaml_path = File.expand_path("~/.config/gprism/config.yaml")
  yaml_path_alt = File.expand_path("~/.gprism.yaml")
  env_path = ".env"

  if File.exist?(yaml_path)
    config = YAML.load_file(yaml_path) || {}
  elsif File.exist?(yaml_path_alt)
    config = YAML.load_file(yaml_path_alt) || {}
  end

  # Fallback to local .env
  if File.exist?(env_path)
    File.readlines(env_path).each do |line|
      next if line.strip.empty? || line.start_with?('#')
      k, v = line.strip.split('=', 2)
      if k.start_with?("GPRISM_")
        config[k.sub("GPRISM_", "").downcase] = v
      end
    end
  end

  # Load from ENV directly if still missing
  config['project_id'] ||= ENV['GPRISM_PROJECT_ID']
  config['identity']   ||= ENV['GPRISM_IDENTITY']
  config['environment'] ||= ENV['GPRISM_ENVIRONMENT']
  config['gcs_bucket'] ||= ENV['GPRISM_GCS_BUCKET']

  config
end

def get_passphrase(env)
  env_var = "GIT_PRIVATIZE_KEY_#{env.upcase}"
  
  if ENV[env_var] || ENV['GIT_PRIVATIZE_KEY']
    if env.start_with?('test')
      warn "Cleartext password used via ENV for testing environment '#{env}'."
      return ENV[env_var] || ENV['GIT_PRIVATIZE_KEY']
    else
      warn "Cleartext password via ENV is ONLY acceptable for 'test*' environments. Ignoring ENV password and falling back to Keychain/Prompt."
    end
  end

  keychain_id = "gprism-#{env}"
  is_mac = RUBY_PLATFORM.include?('darwin')
  is_linux = RUBY_PLATFORM.include?('linux')

  # Try keychain/keyring
  out = ""
  if is_mac
    out = `security find-generic-password -s "#{keychain_id}" -a "#{keychain_id}" -w 2>/dev/null`.strip
  elsif is_linux
    if system("command -v secret-tool >/dev/null 2>&1")
      out = `secret-tool lookup service gprism account "#{keychain_id}" 2>/dev/null`.strip
    end
  end
  return out unless out.empty?

  # Prompt
  print "Enter gprism encryption passphrase for env '#{env}': "
  pass = STDIN.noecho(&:gets).chomp
  puts
  
  # For non-interactive or testing, we shouldn't block, so default to not saving if no terminal
  if STDIN.tty?
    keyring_name = is_mac ? "macOS Keychain" : (is_linux ? "Linux Keyring" : "system keyring")
    print "Save to #{keyring_name}? [Y/n] "
    ans = STDIN.gets.chomp.downcase
    if ans == 'y' || ans.empty?
      if is_mac
        `security add-generic-password -s "#{keychain_id}" -a "#{keychain_id}" -w #{Shellwords.escape(pass)} -U`
        success "Saved to Keychain."
      elsif is_linux
        if system("command -v secret-tool >/dev/null 2>&1")
          IO.popen("secret-tool store --label=\"#{keychain_id}\" service gprism account \"#{keychain_id}\"", "w") do |io|
            io.write(pass)
          end
          if $?.success?
            success "Saved to Linux Keyring."
          else
            warn "Failed to save to Linux Keyring."
          end
        else
          warn "Cannot save: secret-tool not found (install libsecret-tools)."
        end
      else
        warn "Keyring saving not implemented for this OS."
      end
    end
  end
  
  pass
end

def encrypt(data, pass)
  cipher = OpenSSL::Cipher.new('AES-256-CBC')
  cipher.encrypt
  salt = OpenSSL::Random.random_bytes(8)
  key_iv = OpenSSL::PKCS5.pbkdf2_hmac(pass, salt, 2000, cipher.key_len + cipher.iv_len, 'sha256')
  cipher.key = key_iv[0, cipher.key_len]
  cipher.iv = key_iv[cipher.key_len, cipher.iv_len]
  encrypted = cipher.update(data) + cipher.final
  Base64.strict_encode64("Salted__#{salt}#{encrypted}")
end

def decrypt(data, pass)
  decoded = Base64.strict_decode64(data.strip)
  return decoded unless decoded.start_with?("Salted__")
  salt = decoded[8, 8]
  encrypted = decoded[16..-1]
  cipher = OpenSSL::Cipher.new('AES-256-CBC')
  cipher.decrypt
  key_iv = OpenSSL::PKCS5.pbkdf2_hmac(pass, salt, 2000, cipher.key_len + cipher.iv_len, 'sha256')
  cipher.key = key_iv[0, cipher.key_len]
  cipher.iv = key_iv[cipher.key_len, cipher.iv_len]
  cipher.update(encrypted) + cipher.final
rescue => e
  error "Decryption failed! Wrong password? Error: #{e.message}"
end

def get_repo_name
  url = `git config --get remote.origin.url 2>/dev/null`.strip
  return "unknown-repo" if url.empty?
  
  if url.include?(":") && !url.start_with?("http")
    url = url.split(":", 2).last
  end
  
  url = url.sub(%r{^https?://[^/]+/}, "")
  url = url.sub(/\.git$/, "")
  url
end

def get_repo_slug
  get_repo_name.gsub(/[^a-zA-Z0-9]/, '-').gsub(/-+/, '-').sub(/^-/, '').sub(/-$/, '')
end

def generate_secret_name(filepath, env)
  repo_slug = get_repo_slug
  # Replace non-alphanumeric with dashes
  slug = filepath.gsub(/[^a-zA-Z0-9]/, '-')
  slug = slug.gsub(/-+/, '-').sub(/^-/, '').sub(/-$/, '')
  name = "#{env}--#{repo_slug}--#{slug}"
  if name.length > 255
    hash = Digest::SHA256.hexdigest(filepath)[0, 16]
    name = "#{name[0, 230]}-#{hash}"
  end
  name
end

def list_files
  return [] unless File.exist?('.git-privatize.list')
  File.readlines('.git-privatize.list').map(&:strip).reject { |l| l.empty? || l.start_with?('#') }
end

def gcp_secret_exists?(project, name)
  system("gcloud secrets describe #{Shellwords.escape(name)} --project=#{Shellwords.escape(project)} >/dev/null 2>&1")
end

def create_gcp_secret(project, name)
  system("gcloud secrets create #{Shellwords.escape(name)} --replication-policy=automatic --project=#{Shellwords.escape(project)} >/dev/null 2>&1")
end

def add_gcp_secret_version(project, name, content)
  IO.popen("gcloud secrets versions add #{Shellwords.escape(name)} --project=#{Shellwords.escape(project)} --data-file=- >/dev/null 2>&1", "w") do |io|
    io.write(content)
  end
  $?.success?
end

def fetch_gcp_secret_version(project, name)
  `gcloud secrets versions access latest --secret=#{Shellwords.escape(name)} --project=#{Shellwords.escape(project)} 2>/dev/null`
end

def fetch_gcp_secret_timestamp(project, name)
  `gcloud secrets versions describe latest --secret=#{Shellwords.escape(name)} --project=#{Shellwords.escape(project)} --format="value(createTime)" 2>/dev/null`.strip
end

def compare_and_prompt(action, file, name, local_content, remote_content, project)
  local_md5 = Digest::MD5.hexdigest(local_content)
  remote_md5 = Digest::MD5.hexdigest(remote_content)
  
  if local_md5 == remote_md5
    info "#{file} is identical to remote secret #{name}. Skipping #{action}."
    return false
  end
  
  require 'time'
  local_time = File.mtime(file)
  remote_time_str = fetch_gcp_secret_timestamp(project, name)
  remote_time = Time.parse(remote_time_str) rescue Time.at(0)
  
  today = Time.now.strftime("%Y-%m-%d")
  fmt_time = ->(t) { t.strftime("%Y-%m-%d") == today ? t.strftime("%H:%M:%S") : t.strftime("%Y-%m-%d") }
  
  puts "Conflict for #{file}:"
  puts "  Local:  MD5 #{CYAN}#{local_md5[0, 8]}#{RESET}, modified #{fmt_time.call(local_time)}"
  puts "  Remote: MD5 #{BLUE}#{remote_md5[0, 8]}#{RESET}, modified #{fmt_time.call(remote_time)}"
  
  recommended = local_time > remote_time ? "push" : "pull"
  emoji = recommended == "push" ? "⬆️ " : "⬇️ "
  ours_theirs = recommended == "push" ? "(ours)" : "(theirs)"
  
  if recommended == action
    puts "  Recommended direction: #{GREEN}#{emoji} #{recommended.capitalize} #{ours_theirs}#{RESET}"
  else
    puts "  Recommended direction: #{RED}#{emoji} #{recommended.capitalize} #{ours_theirs}#{RESET} (Warning: You are trying to #{action}!)"
  end
  
  if STDIN.tty?
    print "Are you sure you want to #{action} and overwrite? [y/N] "
    ans = STDIN.gets.chomp.downcase
    return ans == 'y'
  else
    warn "Non-interactive mode, skipping #{action} due to conflict."
    return false
  end
end

def update_gitignore(files)
  gitignore = ".gitignore"
  content = File.exist?(gitignore) ? File.read(gitignore) : ""
  lines = content.split("\n").map(&:strip)
  
  needs_newline = !content.empty? && !content.end_with?("\n")
  
  File.open(gitignore, "a") do |f|
    f.puts if needs_newline
    needs_newline = false # only needed once
    
    files.each do |file|
      unless lines.include?(file)
        f.puts file
        success "Added #{file} to .gitignore"
        lines << file # Update lines array to prevent duplicates in same run
      end
    end
  end
end

def warn_if_not_git_ignored(file)
  return unless File.exist?(file)
  
  # Check if we're in a git repo first
  return unless system("git rev-parse --is-inside-work-tree >/dev/null 2>&1")
  
  unless system("git check-ignore -q #{Shellwords.escape(file)} >/dev/null 2>&1")
    warn "Hey its not git ignored: #{file}"
    info "Run this to fix it: echo #{file} >> .gitignore"
  end
end

CONFIG = load_config
warn_if_not_git_ignored('.env')

if CONFIG['project_id'].nil?
  error "Project ID missing. Set GPRISM_PROJECT_ID in .env or config.yaml"
end
ENV_NS = CONFIG['environment'] || 'dev'

case ARGV[0]
when "init"
  unless File.exist?(".env.template")
    File.write(".env.template", "GPRISM_PROJECT_ID=your-gcp-project-id\nGPRISM_IDENTITY=your-email@example.com\nGPRISM_ENVIRONMENT=dev\n")
    success "Created .env.template"
  end
  
  unless File.exist?(".git-privatize.list")
    FileUtils.touch(".git-privatize.list")
    success "Created .git-privatize.list"
  end
  
  bucket_name = CONFIG['gcs_bucket'] || "gs://#{CONFIG['project_id']}-gprism"
  unless bucket_name.start_with?("gs://")
    bucket_name = "gs://#{bucket_name}"
  end
  
  info "Ensuring GCS bucket #{bucket_name} exists..."
  system("gcloud storage buckets create #{Shellwords.escape(bucket_name)} >/dev/null 2>&1")
  
  info "Enabling GCS object versioning..."
  if system("gcloud storage buckets update #{Shellwords.escape(bucket_name)} --versioning >/dev/null 2>&1")
    success "Initialized GCS bucket #{bucket_name} with versioning enabled."
  else
    warn "Failed to update GCS bucket. You may need to create it manually or fix your gcloud auth."
  end

when "push"
  if ARGV[1] == "--all" || ARGV[1] == "-a"
    pass = get_passphrase(ENV_NS)
    files = list_files
    files.each do |file|
      unless File.exist?(file)
        warn "File #{file} not found, skipping."
        next
      end
      
      name = generate_secret_name(file, ENV_NS)
      content = File.read(file)
      enc_content = encrypt(content, pass)
      
      if gcp_secret_exists?(CONFIG['project_id'], name)
        remote_enc_content = fetch_gcp_secret_version(CONFIG['project_id'], name)
        if remote_enc_content && !remote_enc_content.empty?
          if remote_enc_content.start_with?("GPRISM_GCS_URI=")
            gcs_uri = remote_enc_content.sub("GPRISM_GCS_URI=", "").strip
            remote_enc_content = `gcloud storage cp #{Shellwords.escape(gcs_uri)} - 2>/dev/null`
          end
          remote_content = decrypt(remote_enc_content, pass)
          next unless compare_and_prompt("push", file, name, content, remote_content, CONFIG['project_id'])
        end
      else
        create_gcp_secret(CONFIG['project_id'], name)
      end
      
      # Handle large payloads via GCS offloading
      if enc_content.bytesize > 60_000
        bucket = CONFIG['gcs_bucket'] || "#{CONFIG['project_id']}-gprism"
        bucket = bucket.sub(/^gs:\/\//, '')
        
        filepath_slug = file.gsub(/[^a-zA-Z0-9\.\-\/]/, '_')
        gcs_uri = "gs://#{bucket}/#{ENV_NS}/#{get_repo_slug}/#{filepath_slug}.enc"
        
        info "Payload large (>60KB). Offloading to GCS: #{gcs_uri}"
        IO.popen("gcloud storage cp - #{Shellwords.escape(gcs_uri)} >/dev/null 2>&1", "w") do |io|
          io.write(enc_content)
        end
        unless $?.success?
          error "Failed to upload to GCS bucket #{bucket}."
        end
        # The content to push to Secret Manager becomes the pointer
        enc_content = "GPRISM_GCS_URI=#{gcs_uri}"
      end
      
      if add_gcp_secret_version(CONFIG['project_id'], name, enc_content)
        success "Pushed #{file} to Secret Manager as #{name}"
        File.write("#{file}.readme", "This file is managed by gprism. Secret name: #{name}\nRun `gprism pull --all` to restore.")
        update_gitignore([file])
        File.delete(file)
        info "Replaced #{file} with #{CYAN}#{file}.readme#{RESET}"
      else
        error "Failed to push #{file}"
      end
    end
  else
    puts "Usage: gprism push --all"
  end

when "pull"
  if ARGV[1] == "--all" || ARGV[1] == "-a"
    pass = get_passphrase(ENV_NS)
    files = list_files
    files.each do |file|
      name = generate_secret_name(file, ENV_NS)
      
      if !gcp_secret_exists?(CONFIG['project_id'], name)
        warn "Secret #{name} not found in GCP, skipping #{file}."
        next
      end
      
      enc_content = fetch_gcp_secret_version(CONFIG['project_id'], name)
      if enc_content.nil? || enc_content.empty?
        warn "Failed to fetch content for #{name}"
        next
      end
      
      if enc_content.start_with?("GPRISM_GCS_URI=")
        gcs_uri = enc_content.sub("GPRISM_GCS_URI=", "").strip
        info "Large payload detected. Downloading from GCS: #{gcs_uri}"
        enc_content = `gcloud storage cp #{Shellwords.escape(gcs_uri)} - 2>/dev/null`
        if !$?.success? || enc_content.nil? || enc_content.empty?
          error "Failed to download payload from GCS: #{gcs_uri}"
        end
      end
      
      dec_content = decrypt(enc_content, pass)
      
      if File.exist?(file)
        local_content = File.read(file)
        next unless compare_and_prompt("pull", file, name, local_content, dec_content, CONFIG['project_id'])
      end
      
      FileUtils.mkdir_p(File.dirname(file))
      File.delete(file) if File.exist?(file)
      File.write(file, dec_content)
      File.chmod(0400, file)
      success "Restored #{file} from GCP (read-only)"
      if File.exist?("#{file}.readme")
        File.delete("#{file}.readme")
      end
    end
  else
    puts "Usage: gprism pull --all"
  end

when "add"
  file = ARGV[1]
  if file.nil? || file.empty?
    puts "Usage: gprism add <filepath>"
    exit 1
  end
  
  unless File.exist?(file)
    error "File #{file} does not exist locally."
  end
  
  if File.directory?(file)
    error "Folders are not supported. Please add individual files."
  end
  
  File.chmod(0600, file)
  success "Made #{file} writable (0600)"
  list_file = '.git-privatize.list'
  lines = File.exist?(list_file) ? File.readlines(list_file).map(&:strip) : []
  unless lines.include?(file)
    File.open(list_file, "a") { |f| f.puts file }
    success "Added #{file} to #{list_file}"
  else
    info "#{file} is already in #{list_file}"
  end
  
  update_gitignore([file])
  info "Run `gprism push --all` to encrypt and upload."

when "status", "st"
  files = list_files
  if files.empty?
    info "No files listed in .git-privatize.list"
    exit 0
  end
  puts "Gprism Status (Project: #{CONFIG['project_id']}, Env: #{ENV_NS})"
  
  # Carlessian alignment padding
  max_file_len = files.map(&:length).max || 0
  names = files.map { |f| generate_secret_name(f, ENV_NS) }
  max_name_len = names.map(&:length).max || 0
  
  files.each do |file|
    warn_if_not_git_ignored(file)
    name = generate_secret_name(file, ENV_NS)
    in_gcp = gcp_secret_exists?(CONFIG['project_id'], name)
    
    remote_type = nil
    if in_gcp
      payload = fetch_gcp_secret_version(CONFIG['project_id'], name)
      if payload && payload.start_with?("GPRISM_GCS_URI=")
        remote_type = "🪣 GS"
      else
        remote_type = "🔑 SM"
      end
    end
    
    local_exists = File.exist?(file)
    readme_exists = File.exist?("#{file}.readme")
    
    status = []
    if remote_type
      status << "#{GREEN}#{remote_type}#{RESET}"
    else
      status << "#{RED}Missing Remote#{RESET}"
    end
    status << "#{GREEN}Local File#{RESET}" if local_exists
    status << "#{RED}Missing Local#{RESET}" unless local_exists
    status << "#{CYAN}Readme#{RESET}" if readme_exists
    
    pad_file = " " * [0, max_file_len - file.length].max
    pad_name = " " * [0, max_name_len - name.length].max
    
    colorized_file = file
    if File.symlink?(file)
      colorized_file = "#{CYAN}#{file}#{RESET}"
    elsif File.directory?(file)
      colorized_file = "#{BLUE}#{file}#{RESET}"
    elsif File.exist?(file) && File.executable?(file)
      colorized_file = "#{GREEN}#{file}#{RESET}"
    end
    
    puts "💾 #{colorized_file}#{pad_file} -> #{name}#{pad_name} [ #{status.join(' | ')} ]"
  end

when "list", "ls"
  require 'json'
  
  show_all = false
  repo_filter = nil
  raw_repo = nil
  
  ARGV[1..-1].each_with_index do |arg, i|
    if arg == "--all" || arg == "-a"
      show_all = true
    elsif arg == "--repo" || arg == "-r"
      raw_repo = ARGV[i+2]
      # Slugify user's input the same way we slugify URLs (e.g. github/palladius -> github-palladius)
      repo_filter = raw_repo.gsub(/[^a-zA-Z0-9]/, '-').gsub(/-+/, '-').sub(/^-/, '').sub(/-$/, '') if raw_repo
    end
  end
  
  # Default to current repo if no explicit filters are passed
  if !show_all && repo_filter.nil?
    repo_filter = get_repo_slug 
    repo_display_name = get_repo_name
  else
    repo_display_name = raw_repo || repo_filter
  end
  
  puts "#{CYAN}Fetching secrets from GCP Project: #{CONFIG['project_id']}...#{RESET}"
  secrets_json = `gcloud secrets list --project=#{Shellwords.escape(CONFIG['project_id'])} --format=json 2>/dev/null`
  if secrets_json.nil? || secrets_json.strip.empty?
    warn "Failed to fetch secrets or no secrets found."
    exit 0
  end
  
  begin
    secrets = JSON.parse(secrets_json)
  rescue JSON::ParserError
    error "Failed to parse secrets list JSON."
  end
  
  count = 0
  matched_secrets = []
  local_files = list_files
  
  secrets.each do |s|
    secret_name = s["name"].split("/").last
    
    unless show_all
      # Must match env and repo
      if repo_filter
        next unless secret_name.start_with?("#{ENV_NS}--#{repo_filter}--")
      else
        next unless secret_name.start_with?("#{ENV_NS}--")
      end
    end
    
    version_id = `gcloud secrets versions list #{Shellwords.escape(secret_name)} --project=#{Shellwords.escape(CONFIG['project_id'])} --limit=1 --format="value(name)" 2>/dev/null`.strip.split("/").last
    
    if version_id.nil? || version_id.empty?
      puts "🔒 #{secret_name} - #{RED}No versions found#{RESET}"
      next
    end
    
    payload = fetch_gcp_secret_version(CONFIG['project_id'], secret_name)
    size = payload ? payload.bytesize : 0
    size_str = size > 1024 ? "#{size / 1024}KB" : "#{size}B"
    
    if payload && payload.start_with?("GPRISM_GCS_URI=")
      gcs_uri = payload.sub("GPRISM_GCS_URI=", "").strip
      puts "🔑 #{BLUE}#{secret_name}#{RESET} (v#{version_id}) - 🪣 #{CYAN}GS#{RESET} (#{gcs_uri.split('/').last})"
    else
      puts "🔑 #{BLUE}#{secret_name}#{RESET} (v#{version_id}) - 🔑 #{CYAN}SM#{RESET} (#{size_str})"
    end
    
    # Try to extract friendly name
    friendly_name = nil
    if repo_filter
      prefix = "#{ENV_NS}--#{repo_filter}--"
      if secret_name.start_with?(prefix)
        local_match = local_files.find { |f| generate_secret_name(f, ENV_NS) == secret_name }
        if local_match
          friendly_name = local_match
        else
          file_slug = secret_name[prefix.length..-1]
          file_slug = ".#{file_slug[1..-1]}" if file_slug.start_with?("-")
          friendly_name = file_slug
        end
      else
        friendly_name = secret_name
      end
    else
      friendly_name = secret_name
    end
    matched_secrets << friendly_name
    
    count += 1
  end
  
  msg = "\nFound #{count} secrets"
  msg += " for env '#{ENV_NS}'" unless show_all
  msg += " and repo '#{repo_display_name}'" if repo_display_name
  
  if count > 0
    msg += ":\n" + matched_secrets.map { |f| "- #{f}" }.join("\n")
  else
    msg += "."
  end
  
  puts msg

  # --- GCS Server-Side Listing ---
  bucket_name = CONFIG['gcs_bucket'] || "gs://#{CONFIG['project_id']}-gprism"
  unless bucket_name.start_with?("gs://")
    bucket_name = "gs://#{bucket_name}"
  end
  
  puts "\n#{CYAN}Checking GCS storage for repo '#{repo_display_name}' in env '#{ENV_NS}'...#{RESET}"
  gcs_path = "#{bucket_name}/#{ENV_NS}/#{repo_filter}/"
  gcs_output = `gcloud storage ls #{Shellwords.escape(gcs_path)} 2>/dev/null`.strip
  
  if gcs_output.empty?
    puts "No offloaded files found in GCS bucket."
  else
    puts "🪣 Remote GCS blobs:"
    gcs_output.split("\n").each do |line|
      next if line.strip.empty? || !line.start_with?("gs://")
      # line is like gs://bucket/dev/repo/path_slug.enc
      file_path = line.sub(gcs_path, "")
      puts "  - #{GREEN}#{file_path}#{RESET} (in GCS)"
    end
  end

else
  puts "Usage: gprism [init|add|push|pull|status|st|list|ls] <args>"
end
